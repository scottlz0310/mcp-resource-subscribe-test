{
  "name": "mcp-resource-subscriber",
  "version": "0.1.0",
  "description": "CLI probe for MCP resource subscriptions — subscribe to MCP resources, receive live update notifications, and re-read updated content.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcp-resource-subscriber": "dist/src/cli.js"
  },
  "files": [
    "dist/",
    "!dist/test/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scottlz0310/mcp-resource-subscriber.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "probe:subscribe": "tsx scripts/subscribe-client.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
